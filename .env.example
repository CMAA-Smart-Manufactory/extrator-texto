# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# OCR Configuration
OCR_LANGUAGE=pt
OCR_GPU=false

# File Handling
MAX_FILE_SIZE=52428800  # 50MB
TEMP_DIR=/tmp/leitor_arquivos
CACHE_DIR=.cache

# Security
ALLOWED_ORIGINS=*
API_KEY=your-secret-key-here

# Logging
LOG_LEVEL=INFO
